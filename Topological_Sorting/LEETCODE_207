int dfs(int course, int** graph, int* graphSize, int* visited) {
    if (visited[course] == 1)  
        return 0;
    if (visited[course] == 2)  
        return 1;

    visited[course] = 1;  

    for (int i = 0; i < graphSize[course]; i++) {
        if (!dfs(graph[course][i], graph, graphSize, visited))
            return 0;
    }

    visited[course] = 2;  
    return 1;
}
bool canFinish(int numCourses, int** prerequisites, int prerequisitesSize, int* prerequisitesColSize) {
    int** graph = (int**)malloc(numCourses * sizeof(int*));
    int* graphSize = (int*)calloc(numCourses, sizeof(int));
    for (int i = 0; i < numCourses; i++)
        graph[i] = (int*)malloc(numCourses * sizeof(int));

    for (int i = 0; i < prerequisitesSize; i++) {
        int course = prerequisites[i][0];
        int pre = prerequisites[i][1];
        graph[pre][graphSize[pre]++] = course;
    }

    int* visited = (int*)calloc(numCourses, sizeof(int));

    
    for (int i = 0; i < numCourses; i++) {
        if (!dfs(i, graph, graphSize, visited)) {
            // Free memory before returning
            for (int j = 0; j < numCourses; j++) free(graph[j]);
            free(graph);
            free(graphSize);
            free(visited);
            return false;
        }
    }

    for (int i = 0; i < numCourses; i++) free(graph[i]);
    free(graph);
    free(graphSize);
    free(visited);

    return true; 
}
